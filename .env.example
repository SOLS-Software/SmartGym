DATABASE_URL="postgresql://postgres:postgres@localhost:5432/smartgym?schema=public"
API_PORT="3333"
# Segredo de assinatura dos JWTs da API — minimo de 32 caracteres aleatorios.
# Gere um valor com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="troque-por-um-segredo-aleatorio-de-pelo-menos-32-caracteres"
# Origens permitidas no CORS em producao (separadas por virgula). Em dev e liberado.
CORS_ORIGINS="https://app.seudominio.com.br"
API_URL="http://localhost:3333"
NEXT_PUBLIC_API_URL="http://localhost:3333"
EXPO_PUBLIC_API_URL="http://localhost:3333"
SUPABASE_URL="https://seu-projeto.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="sua-service-role-key"
SUPABASE_STORAGE_BUCKET="aluno-arquivos"
COMPREFACE_URL="http://localhost:8000"
COMPREFACE_RECOGNITION_API_KEY="sua-chave-do-servico-de-reconhecimento"
COMPREFACE_DET_PROB_THRESHOLD="0.8"
COMPREFACE_SIMILARITY_THRESHOLD="0.85"
