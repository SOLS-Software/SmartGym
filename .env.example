DATABASE_URL="postgresql://postgres:postgres@localhost:5432/smartgym?schema=public"
API_PORT="3333"
# Segredo de assinatura dos JWTs da API — minimo de 32 caracteres aleatorios.
# Gere um valor com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="troque-por-um-segredo-aleatorio-de-pelo-menos-32-caracteres"
# Origens permitidas no CORS em producao (separadas por virgula). Em dev e liberado.
CORS_ORIGINS="https://app.seudominio.com.br"
# Chave de criptografia de PII (CPF, biometria) — minimo 32 caracteres aleatorios.
# ATENCAO: perder esta chave torna os CPFs criptografados irrecuperaveis.
PII_ENCRYPTION_KEY="troque-por-uma-chave-aleatoria-de-pelo-menos-32-caracteres"
# URL base do web app — usada nos links de redefinicao de senha por email.
WEB_APP_URL="http://localhost:3000"
API_URL="http://localhost:3333"
NEXT_PUBLIC_API_URL="http://localhost:3333"
EXPO_PUBLIC_API_URL="http://localhost:3333"
SUPABASE_URL="https://seu-projeto.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="sua-service-role-key"
SUPABASE_STORAGE_BUCKET="aluno-arquivos"
COMPREFACE_URL="http://localhost:8000"
COMPREFACE_RECOGNITION_API_KEY="sua-chave-do-servico-de-reconhecimento"
COMPREFACE_DET_PROB_THRESHOLD="0.8"
COMPREFACE_SIMILARITY_THRESHOLD="0.85"
# Integracao com catracas Control iD (anti-forja de eventos de acesso).
# Quando "true", TODA catraca precisa ter `caToken` configurado e enviar o token
# correspondente (header x-controlid-token ou campo token/push_token no body) em
# cada push; pushes de catracas sem token sao rejeitados com 401. Ative apenas
# depois de provisionar o token em todas as catracas ja em campo. Default:
# desligado (vazio ou qualquer valor != "true") - catracas auto-registradas sem
# token continuam sendo aceitas para nao quebrar o fluxo de ativacao.
CONTROLID_REQUIRE_TOKEN=""
