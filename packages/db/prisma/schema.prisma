generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"] // Required for the extensions block
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

model Empresa {
  id                 Int                                   @id @default(autoincrement())
  idTema             Int?
  dsEmpresa          String                                @db.VarChar(255)
  caCNPJ             String                                @unique @db.VarChar(14)
  anCEP              String?                               @db.VarChar(8)
  anLogradouro       String?                               @db.VarChar(150)
  nrEndereco         String?                               @db.VarChar(10)
  anBairro           String?                               @db.VarChar(100)
  anCidade           String?                               @db.VarChar(100)
  anUF               String?                               @db.VarChar(2)
  nrDDD              Int?
  nrContato          String?                               @db.VarChar(11)
  geoEmpresa         Unsupported("geometry(Point, 4326)")?
  dtCadastro         DateTime                              @default(now())
  dtAlteracao        DateTime                              @updatedAt
  idUsuarioCadastro  Int?
  idUsuarioAlteracao Int?
  boInativo          Boolean                               @default(false)

  pontuacoes                  Pontuacao[]
  atividades                  Atividade[]
  atividadeAgendas            AtividadeAgenda[]
  alunoAtividadeAgendas       AlunoAtividadeAgenda[]
  exercicios                  Exercicio[]
  produtos                    Produto[]
  treinos                     Treino[]
  esportes                    Esporte[]
  categorias                  Categoria[]
  promocoes                   Promocao[]
  planoAtividades             PlanoAtividade[]
  planoProdutos               PlanoProduto[]
  planoEmpresas               PlanoEmpresa[]
  planoValores                PlanoValor[]
  promocaoPlanos              PromocaoPlano[]
  promocaoProdutos            PromocaoProduto[]
  pagamentos                  Pagamento[]
  treinoExercicios            TreinoExercicio[]
  alunosPontuacoes            AlunoPontuacao[]
  produtoMovimentacoes        ProdutoMovimentacao[]
  fornecedores                Fornecedor[]
  empresaArquivos             EmpresaArquivo[]
  alunoCheckIns               AlunoCheckIn[]
  funcionarios                Funcionario[]
  funcionarioAtividadeAgendas FuncionarioAtividadeAgenda[]
  catracas                    Catraca[]
  localidades                 Localidade[]
  idCliente                   Int
  tema                        Tema?                        @relation(fields: [idTema], references: [id])
  cliente                     Cliente                      @relation(fields: [idCliente], references: [id])
  temaCustomizado             TemaCustomizado?

  @@index([geoEmpresa], name: "geo_empresa", type: Gist)
  @@index([idCliente])
  @@map("tb_Empresas")
}

model Plano {
  id                 Int      @id @default(autoincrement())
  dsPlano            String   @db.VarChar(255)
  idFrequencia       Int?
  dtCadastro         DateTime @default(now())
  dtAlteracao        DateTime @updatedAt
  idUsuarioCadastro  Int?
  idUsuarioAlteracao Int?
  boInativo          Boolean  @default(false)

  frequencia      Frequencia?      @relation(fields: [idFrequencia], references: [id])
  planoAtividades PlanoAtividade[]
  planoProdutos   PlanoProduto[]
  planoEmpresas   PlanoEmpresa[]
  planoValores    PlanoValor[]
  promocaoPlanos  PromocaoPlano[]
  alunoPlanos     AlunoPlano[]

  @@map("tb_Planos")
}

model Pontuacao {
  id                 Int      @id @default(autoincrement())
  idEmpresa          Int
  dsPontuacao        String   @db.VarChar(255)
  qtPontos           Int      @default(0)
  dtCadastro         DateTime @default(now())
  dtAlteracao        DateTime @updatedAt
  idUsuarioCadastro  Int?
  idUsuarioAlteracao Int?
  boInativo          Boolean  @default(false)

  empresa          Empresa          @relation(fields: [idEmpresa], references: [id])
  alunosPontuacoes AlunoPontuacao[]
  alunoCheckIns    AlunoCheckIn[]

  @@index([idEmpresa])
  @@map("tb_Pontuacoes")
}

model Atividade {
  id                 Int      @id @default(autoincrement())
  idEmpresa          Int?
  idEsporte          Int?
  dsAtividade        String   @db.VarChar(255)
  dtCadastro         DateTime @default(now())
  dtAlteracao        DateTime @updatedAt
  idUsuarioCadastro  Int?
  idUsuarioAlteracao Int?
  boInativo          Boolean  @default(false)

  empresa          Empresa?          @relation(fields: [idEmpresa], references: [id])
  esporte          Esporte?          @relation(fields: [idEsporte], references: [id])
  atividadeAgendas AtividadeAgenda[]
  planoAtividades  PlanoAtividade[]

  @@index([idEmpresa])
  @@index([idEsporte])
  @@map("tb_Atividades")
}

model AtividadeAgenda {
  id                 Int       @id @default(autoincrement())
  idEmpresa          Int
  idAtividade        Int
  idCategoria        Int?
  idLocalidade       Int?
  dtInicial          DateTime?
  dtFinal            DateTime?
  qtAlunos           Int?
  dtCadastro         DateTime  @default(now())
  dtAlteracao        DateTime  @updatedAt
  idUsuarioCadastro  Int?
  idUsuarioAlteracao Int?
  boInativo          Boolean   @default(false)

  empresa                     Empresa                      @relation(fields: [idEmpresa], references: [id])
  atividade                   Atividade                    @relation(fields: [idAtividade], references: [id])
  categoria                   Categoria?                   @relation(fields: [idCategoria], references: [id])
  localidade                  Localidade?                  @relation(fields: [idLocalidade], references: [id])
  alunoAtividadeAgendas       AlunoAtividadeAgenda[]
  funcionarioAtividadeAgendas FuncionarioAtividadeAgenda[]
  alunoCheckIns               AlunoCheckIn[]

  @@index([idEmpresa])
  @@index([idAtividade])
  @@index([idCategoria])
  @@index([idLocalidade])
  @@map("tb_AtividadeAgendas")
}

model AlunoAtividadeAgenda {
  id                Int      @id @default(autoincrement())
  idEmpresa         Int
  idAtividadeAgenda Int
  idAluno           Int
  dtCadastro        DateTime @default(now())
  dtAlteracao       DateTime @updatedAt
  boInativo         Boolean  @default(false)

  empresa         Empresa         @relation(fields: [idEmpresa], references: [id])
  atividadeAgenda AtividadeAgenda @relation(fields: [idAtividadeAgenda], references: [id])
  aluno           Aluno           @relation(fields: [idAluno], references: [id])

  @@index([idEmpresa])
  @@index([idAtividadeAgenda])
  @@index([idAluno])
  @@map("tb_AlunoAtividadeAgendas")
}

model FuncionarioAtividadeAgenda {
  id                Int      @id @default(autoincrement())
  idEmpresa         Int
  idAtividadeAgenda Int
  idFuncionario     Int
  dtCadastro        DateTime @default(now())
  dtAlteracao       DateTime @updatedAt
  boInativo         Boolean  @default(false)

  empresa         Empresa         @relation(fields: [idEmpresa], references: [id])
  atividadeAgenda AtividadeAgenda @relation(fields: [idAtividadeAgenda], references: [id])
  funcionario     Funcionario     @relation(fields: [idFuncionario], references: [id])

  @@index([idEmpresa])
  @@index([idAtividadeAgenda])
  @@index([idFuncionario])
  @@map("tb_FuncionarioAtividadeAgendas")
}

model Exercicio {
  id                 Int      @id @default(autoincrement())
  idEmpresa          Int?
  dsExercicio        String   @db.VarChar(255)
  dsInstrucao        String?  @db.Text
  dtCadastro         DateTime @default(now())
  dtAlteracao        DateTime @updatedAt
  idUsuarioCadastro  Int?
  idUsuarioAlteracao Int?
  boInativo          Boolean  @default(false)

  empresa              Empresa?                @relation(fields: [idEmpresa], references: [id])
  exercicioEquipamento ExercicioEquipamento[]
  treinoExercicios     TreinoExercicio[]
  exercicioArquivos    ExercicioArquivo[]
  exercicioAreas       ExercicioAreaCorporal[]

  @@index([idEmpresa])
  @@map("tb_Exercicios")
}

model AreaCorporal {
  id             Int      @id @default(autoincrement())
  dsAreaCorporal String   @db.VarChar(100)
  dtCadastro     DateTime @default(now())
  dtAlteracao    DateTime @updatedAt
  boInativo      Boolean  @default(false)

  exercicioAreas ExercicioAreaCorporal[]

  @@map("tb_AreasCorporais")
}

model ExercicioAreaCorporal {
  id             Int      @id @default(autoincrement())
  idExercicio    Int
  idAreaCorporal Int
  dtCadastro     DateTime @default(now())
  dtAlteracao    DateTime @updatedAt
  boInativo      Boolean  @default(false)

  exercicio    Exercicio    @relation(fields: [idExercicio], references: [id])
  areaCorporal AreaCorporal @relation(fields: [idAreaCorporal], references: [id])

  @@index([idExercicio])
  @@index([idAreaCorporal])
  @@map("tb_ExercicioAreasCorporais")
}

model Produto {
  id                 Int      @id @default(autoincrement())
  idEmpresa          Int?
  dsProduto          String   @db.VarChar(255)
  qtEstoque          Int      @default(0)
  dtCadastro         DateTime @default(now())
  dtAlteracao        DateTime @updatedAt
  idUsuarioCadastro  Int?
  idUsuarioAlteracao Int?
  boInativo          Boolean  @default(false)

  empresa              Empresa?              @relation(fields: [idEmpresa], references: [id])
  planoProdutos        PlanoProduto[]
  promocaoProdutos     PromocaoProduto[]
  produtoMovimentacoes ProdutoMovimentacao[]
  produtoArquivos      ProdutoArquivo[]

  @@index([idEmpresa])
  @@map("tb_Produtos")
}

model Treino {
  id                 Int      @id @default(autoincrement())
  idEmpresa          Int?
  idAluno            Int?
  idNivel            Int?
  dsTreino           String   @db.VarChar(255)
  dtCadastro         DateTime @default(now())
  dtAlteracao        DateTime @updatedAt
  idUsuarioCadastro  Int?
  idUsuarioAlteracao Int?
  boInativo          Boolean  @default(false)

  empresa          Empresa?          @relation(fields: [idEmpresa], references: [id])
  aluno            Aluno?            @relation(fields: [idAluno], references: [id])
  nivel            Nivel?            @relation(fields: [idNivel], references: [id])
  treinoExercicios TreinoExercicio[]
  alunoTreinos     AlunoTreino[]

  @@index([idEmpresa])
  @@index([idAluno])
  @@map("tb_Treinos")
}

model Esporte {
  id                 Int      @id @default(autoincrement())
  idEmpresa          Int?
  dsEsporte          String   @db.VarChar(255)
  dtCadastro         DateTime @default(now())
  dtAlteracao        DateTime @updatedAt
  idUsuarioCadastro  Int?
  idUsuarioAlteracao Int?
  boInativo          Boolean  @default(false)

  empresa    Empresa?    @relation(fields: [idEmpresa], references: [id])
  atividades Atividade[]
  categorias Categoria[]

  @@index([idEmpresa])
  @@map("tb_Esportes")
}

model Categoria {
  id                 Int      @id @default(autoincrement())
  idEmpresa          Int?
  idEsporte          Int?
  dsCategoria        String   @db.VarChar(255)
  dtCadastro         DateTime @default(now())
  dtAlteracao        DateTime @updatedAt
  idUsuarioCadastro  Int?
  idUsuarioAlteracao Int?
  boInativo          Boolean  @default(false)

  empresa          Empresa?          @relation(fields: [idEmpresa], references: [id])
  esporte          Esporte?          @relation(fields: [idEsporte], references: [id])
  atividadeAgendas AtividadeAgenda[]

  @@index([idEmpresa])
  @@index([idEsporte])
  @@map("tb_Categorias")
}

model Aluno {
  id                 Int       @id @default(autoincrement())
  nmAluno            String    @default("") @db.VarChar(255)
  caCPF              String    @default("") @db.VarChar(11)
  dtNascimento       DateTime? @db.Date
  nrDDD              Int       @default(0)
  nrContato          String?   @db.VarChar(9)
  anEmail            String    @default("") @db.VarChar(100)
  anCEP              String    @default("") @db.VarChar(8)
  anLogradouro       String    @default("") @db.VarChar(150)
  anComplemento      String    @default("") @db.VarChar(100)
  anBairro           String    @default("") @db.VarChar(100)
  nrEndereco         String?   @db.VarChar(10)
  idCliente          Int
  dtCadastro         DateTime  @default(now())
  dtAlteracao        DateTime  @updatedAt
  idUsuarioCadastro  Int?
  idUsuarioAlteracao Int?
  boInativo          Boolean   @default(false)

  alunoEvolucoes        AlunoEvolucao[]
  alunoPlanos           AlunoPlano[]
  treinos               Treino[]
  alunoTreinos          AlunoTreino[]
  alunoAtividadeAgendas AlunoAtividadeAgenda[]
  alunoCheckIns         AlunoCheckIn[]
  alunosPontuacoes      AlunoPontuacao[]
  produtoMovimentacoes  ProdutoMovimentacao[]
  alunoArquivos         AlunoArquivo[]
  usuarios              Usuario[]
  alunobiometriafacial  AlunoBiometriaFacial[]
  cliente               Cliente                @relation(fields: [idCliente], references: [id])

  @@unique([idCliente, caCPF])
  @@map("tb_Alunos")
}

model Funcionario {
  id                 Int       @id @default(autoincrement())
  idEmpresa          Int?
  idCargo            Int?
  nmFuncionario      String    @default("") @db.VarChar(255)
  caCPF              String    @default("") @db.VarChar(11)
  dtNascimento       DateTime? @db.Date
  nrDDD              Int?
  nrContato          String?   @db.VarChar(9)
  anEmail            String    @default("") @db.VarChar(100)
  dtAdmissao         DateTime? @default(now())
  dtCadastro         DateTime  @default(now())
  dtAlteracao        DateTime  @updatedAt
  idUsuarioCadastro  Int?
  idUsuarioAlteracao Int?
  boInativo          Boolean   @default(false)

  empresa                     Empresa?                     @relation(fields: [idEmpresa], references: [id])
  cargo                       Cargo?                       @relation(fields: [idCargo], references: [id])
  usuarios                    Usuario[]
  alunoTreinos                AlunoTreino[]
  alunoEvolucoes              AlunoEvolucao[]
  funcionarioArquivos         FuncionarioArquivo[]
  funcionarioAtividadeAgendas FuncionarioAtividadeAgenda[]

  @@unique([idEmpresa, caCPF])
  @@map("tb_Funcionarios")
}

model FuncionarioArquivo {
  id              Int      @id @default(autoincrement())
  idFuncionario   Int
  idTiposArquivos Int?
  dsArquivo       String   @default("") @db.VarChar(255)
  anCaminho       String   @default("") @db.VarChar(255)
  cnChaveAcesso   Int?
  cnDistribuidor  Int?
  dtCadastro      DateTime @default(now())
  dtAlteracao     DateTime @updatedAt
  boInativo       Boolean  @default(false)

  funcionario Funcionario  @relation(fields: [idFuncionario], references: [id])
  tipoArquivo TipoArquivo? @relation(fields: [idTiposArquivos], references: [id])

  @@index([idFuncionario])
  @@map("tb_FuncionarioArquivos")
}

model Usuario {
  id                 Int       @id @default(autoincrement())
  idFuncionario      Int?
  idAluno            Int?
  dsLogin            String    @unique @default("") @db.VarChar(100)
  dtUltimoAcesso     DateTime?
  dtCadastro         DateTime  @default(now())
  dtAlteracao        DateTime  @updatedAt
  idUsuarioCadastro  Int?
  idUsuarioAlteracao Int?
  boInativo          Boolean   @default(false)

  funcionario Funcionario? @relation(fields: [idFuncionario], references: [id])
  aluno       Aluno?       @relation(fields: [idAluno], references: [id])
  senhas      Senha[]

  @@index([idFuncionario])
  @@index([idAluno])
  @@map("tb_Usuarios")
}

model Senha {
  id                 Int       @id @default(autoincrement())
  idUsuario          Int
  dsSenha            String?   @db.VarChar(255)
  cnTipoHash         Int?
  dtExpiracao        DateTime?
  boTrocaObrigatoria Boolean   @default(false)
  dtCadastro         DateTime  @default(now())
  dtAlteracao        DateTime  @updatedAt
  idUsuarioCadastro  Int?
  idUsuarioAlteracao Int?
  boInativo          Boolean   @default(false)

  usuario Usuario @relation(fields: [idUsuario], references: [id])

  @@index([idUsuario])
  @@map("tb_Senhas")
}

model Promocao {
  id                 Int       @id @default(autoincrement())
  idEmpresa          Int?
  dsPromocao         String    @default("") @db.VarChar(255)
  qtPeriodo          Int       @default(0)
  idUnidadeTempo     Int?
  vlDesconto         Decimal?  @default(0) @db.Decimal(12, 4)
  pcDesconto         Decimal?  @default(0) @db.Decimal(12, 4)
  dtInicio           DateTime? @default(now())
  dtEncerramento     DateTime?
  dtCadastro         DateTime  @default(now())
  dtAlteracao        DateTime  @updatedAt
  idUsuarioCadastro  Int?
  idUsuarioAlteracao Int?
  boInativo          Boolean   @default(false)

  empresa          Empresa?          @relation(fields: [idEmpresa], references: [id])
  unidadeTempo     UnidadeTempo?     @relation(fields: [idUnidadeTempo], references: [id])
  promocaoPlanos   PromocaoPlano[]
  promocaoProdutos PromocaoProduto[]
  promocaoArquivos PromocaoArquivo[]

  @@index([idEmpresa])
  @@map("tb_Promocoes")
}

model PlanoAtividade {
  id          Int      @id @default(autoincrement())
  idEmpresa   Int?
  idPlano     Int
  idAtividade Int
  dtCadastro  DateTime @default(now())
  dtAlteracao DateTime @updatedAt
  boInativo   Boolean  @default(false)

  empresa   Empresa?  @relation(fields: [idEmpresa], references: [id])
  plano     Plano     @relation(fields: [idPlano], references: [id])
  atividade Atividade @relation(fields: [idAtividade], references: [id])

  @@index([idEmpresa])
  @@index([idPlano])
  @@index([idAtividade])
  @@map("tb_PlanoAtividades")
}

model PlanoProduto {
  id          Int      @id @default(autoincrement())
  idEmpresa   Int?
  idPlano     Int
  idProduto   Int
  dtCadastro  DateTime @default(now())
  dtAlteracao DateTime @updatedAt
  boInativo   Boolean  @default(false)

  empresa Empresa? @relation(fields: [idEmpresa], references: [id])
  plano   Plano    @relation(fields: [idPlano], references: [id])
  produto Produto  @relation(fields: [idProduto], references: [id])

  @@index([idEmpresa])
  @@index([idPlano])
  @@index([idProduto])
  @@map("tb_PlanoProdutos")
}

model PlanoEmpresa {
  id          Int      @id @default(autoincrement())
  idEmpresa   Int
  idPlano     Int
  dtCadastro  DateTime @default(now())
  dtAlteracao DateTime @updatedAt
  boInativo   Boolean  @default(false)

  empresa Empresa @relation(fields: [idEmpresa], references: [id])
  plano   Plano   @relation(fields: [idPlano], references: [id])

  @@index([idEmpresa])
  @@index([idPlano])
  @@map("tb_PlanoEmpresas")
}

model PlanoValor {
  id                 Int      @id @default(autoincrement())
  idEmpresa          Int?
  idPlano            Int
  vlVenda            Decimal? @default(0) @db.Decimal(12, 4)
  dtCadastro         DateTime @default(now())
  dtAlteracao        DateTime @updatedAt
  idUsuarioCadastro  Int?
  idUsuarioAlteracao Int?
  boInativo          Boolean  @default(false)

  empresa Empresa? @relation(fields: [idEmpresa], references: [id])
  plano   Plano    @relation(fields: [idPlano], references: [id])

  @@index([idEmpresa])
  @@index([idPlano])
  @@map("tb_PlanoValores")
}

model PromocaoPlano {
  id             Int       @id @default(autoincrement())
  idEmpresa      Int?
  idPromocao     Int
  idPlano        Int
  qtDisponivel   Int       @default(0)
  dtInicio       DateTime? @default(now())
  dtEncerramento DateTime?
  dtCadastro     DateTime  @default(now())
  dtAlteracao    DateTime  @updatedAt
  boInativo      Boolean   @default(false)

  empresa     Empresa?     @relation(fields: [idEmpresa], references: [id])
  promocao    Promocao     @relation(fields: [idPromocao], references: [id])
  plano       Plano        @relation(fields: [idPlano], references: [id])
  alunoPlanos AlunoPlano[]

  @@index([idEmpresa])
  @@index([idPromocao])
  @@index([idPlano])
  @@map("tb_PromocaoPlanos")
}

model PromocaoProduto {
  id           Int      @id @default(autoincrement())
  idEmpresa    Int?
  idPromocao   Int
  idProduto    Int
  qtDisponivel Int?
  dtCadastro   DateTime @default(now())
  dtAlteracao  DateTime @updatedAt
  boInativo    Boolean  @default(false)

  empresa  Empresa? @relation(fields: [idEmpresa], references: [id])
  promocao Promocao @relation(fields: [idPromocao], references: [id])
  produto  Produto  @relation(fields: [idProduto], references: [id])

  @@index([idEmpresa])
  @@index([idPromocao])
  @@index([idProduto])
  @@map("tb_PromocaoProdutos")
}

model AlunoEvolucao {
  id                 Int      @id @default(autoincrement())
  idAluno            Int
  idFuncionario      Int?
  vlAltura           Decimal? @default(0) @db.Decimal(5, 2)
  vlPeso             Decimal? @default(0) @db.Decimal(5, 2)
  dtCadastro         DateTime @default(now())
  dtAlteracao        DateTime @updatedAt
  idUsuarioCadastro  Int?
  idUsuarioAlteracao Int?
  boInativo          Boolean  @default(false)

  aluno       Aluno        @relation(fields: [idAluno], references: [id])
  funcionario Funcionario? @relation(fields: [idFuncionario], references: [id])

  @@index([idAluno])
  @@index([idFuncionario])
  @@map("tb_AlunoEvolucoes")
}

model AlunoPlano {
  id                 Int       @id @default(autoincrement())
  idAluno            Int
  idPlano            Int
  idPromocaoPlano    Int?
  nrDiaPagamento     Int       @default(1)
  qtParcelas         Int       @default(1)
  dtAdmissao         DateTime? @default(now())
  dtVencimento       DateTime?
  dtEncerramento     DateTime?
  dtCadastro         DateTime  @default(now())
  dtAlteracao        DateTime  @updatedAt
  idUsuarioCadastro  Int?
  idUsuarioAlteracao Int?
  boInativo          Boolean   @default(false)

  aluno         Aluno          @relation(fields: [idAluno], references: [id])
  plano         Plano          @relation(fields: [idPlano], references: [id])
  promocaoPlano PromocaoPlano? @relation(fields: [idPromocaoPlano], references: [id])
  pagamentos    Pagamento[]
  alunoCheckIns AlunoCheckIn[]

  @@index([idAluno])
  @@index([idPlano])
  @@index([idPromocaoPlano])
  @@map("tb_AlunoPlanos")
}

model Pagamento {
  id                    Int       @id @default(autoincrement())
  idEmpresa             Int
  idAlunoPlano          Int?
  idProdutoMovimentacao Int?
  idStatusPagamento     Int
  idFormaPagamento      Int?
  vlPrevisto            Decimal   @default(0) @db.Decimal(12, 4)
  vlPago                Decimal?  @db.Decimal(12, 4)
  dtCompetencia         DateTime? @db.Date
  dtVencimento          DateTime?
  dtPagamento           DateTime?
  dtCadastro            DateTime  @default(now())
  dtAlteracao           DateTime  @updatedAt
  idUsuarioCadastro     Int?
  idUsuarioAlteracao    Int?
  boInativo             Boolean   @default(false)

  empresa             Empresa              @relation(fields: [idEmpresa], references: [id])
  alunoPlano          AlunoPlano?          @relation(fields: [idAlunoPlano], references: [id])
  produtoMovimentacao ProdutoMovimentacao? @relation(fields: [idProdutoMovimentacao], references: [id])
  statusPagamento     StatusPagamento      @relation(fields: [idStatusPagamento], references: [id])
  formaPagamento      FormaPagamento?      @relation(fields: [idFormaPagamento], references: [id])

  @@index([idAlunoPlano])
  @@index([idStatusPagamento, dtVencimento])
