model TemaCustomizado {
  id                Int      @id @default(autoincrement())
  idCliente         Int?     @unique
  idEmpresa         Int?     @unique
  corPrimaria       String   @default("#000000") @db.VarChar(7)
  corSecundaria     String   @default("#FFFFFF") @db.VarChar(7)
  corAcentuacao     String   @default("#FF0000") @db.VarChar(7)
  corTexto          String   @default("#000000") @db.VarChar(7)
  corFundo          String   @default("#FFFFFF") @db.VarChar(7)
  fontePrincipal    String   @default("Roboto") @db.VarChar(100)
  fonteSecundaria   String   @default("Open Sans") @db.VarChar(100)
  tamanhoBase       Int      @default(14)
  espacamentoPadrao Int      @default(16)
  raioCardBorder    Int      @default(8)
  boModoEscuro      Int      @default(0)
  idArquivoLogo            Int?
  idArquivoFavicon         Int?
  idClienteArquivoLogo     Int?
  idClienteArquivoFavicon  Int?
  dtCadastro               DateTime @default(now())
  dtAlteracao       DateTime @updatedAt
  boInativo         Int      @default(0)

  cliente               Cliente?         @relation(fields: [idCliente], references: [id], onDelete: Cascade)
  empresa               Empresa?         @relation(fields: [idEmpresa], references: [id], onDelete: Cascade)
  arquivoLogo           EmpresaArquivo?  @relation("logo", fields: [idArquivoLogo], references: [id])
  arquivoFavicon        EmpresaArquivo?  @relation("favicon", fields: [idArquivoFavicon], references: [id])
  clienteArquivoLogo    ClienteArquivo?  @relation("clienteLogo", fields: [idClienteArquivoLogo], references: [id])
  clienteArquivoFavicon ClienteArquivo?  @relation("clienteFavicon", fields: [idClienteArquivoFavicon], references: [id])

  @@map("tb_TemasCustomizados")
}

