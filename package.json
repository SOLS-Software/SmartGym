{
  "name": "smartgym",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write .",
    "db:generate": "pnpm --filter @smartgym/db db:generate",
    "db:migrate": "pnpm --filter @smartgym/db db:migrate",
    "db:seed": "pnpm --filter @smartgym/db db:seed",
    "db:studio": "pnpm --filter @smartgym/db db:studio"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "dependencies": {}
}
