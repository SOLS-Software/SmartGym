{
  "name": "@smartgym/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists ../../.env --env-file-if-exists ../../packages/db/.env src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/multipart": "^10.0.0",
    "@smartgym/db": "workspace:*",
    "@smartgym/shared": "workspace:*",
    "@supabase/supabase-js": "^2.105.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "nodemailer": "^8.0.7"
  },
  "devDependencies": {
    "@smartgym/config": "workspace:*",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^8.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
