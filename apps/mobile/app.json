{
  "expo": {
    "name": "SmartGym",
    "slug": "smartgym",
    "scheme": "smartgym",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir que o SmartGym use a camera para anexar fotos ao cadastro do aluno."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "android": {
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.anonymous.smartgym"
    },
    "ios": {
      "bundleIdentifier": "com.anonymous.smartgym"
    }
  }
}
