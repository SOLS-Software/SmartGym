{
  "extends": "@smartgym/config/tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "noEmit": true,
    "paths": {
      "*": ["./*"],
      "expo-router": ["../../node_modules/expo-router"],
      "expo-router/*": ["../../node_modules/expo-router/*"],
      "expo-status-bar": ["../../node_modules/expo-status-bar"]
    }
  },
  "include": [
    "app",
    "lib",
    "types",
    "expo-env.d.ts",
    ".expo/types/**/*.ts"
  ]
}
